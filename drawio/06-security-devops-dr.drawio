<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0" compressed="false"><diagram id="1d8a6e0c393b" name="1. Deploy an application release"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Security, DevOps and Disaster Recovery&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Deploy an application release&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 1/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Build an application change and deploy an approved immutable image to EKS.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;CI should create artifacts while Git remains the auditable desired state for deployment.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;GitHub Actions uses OIDC to build, test, scan, sign, and publish an ECR digest; it opens a production GitOps PR; Argo CD reconciles the reviewed merge.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Developer&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Local Git checkout&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;reviewed commit&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;CI publishes; GitOps promotes.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Push the reviewed application change&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;GitHub&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Application repository&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;push event&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The developer pushes a reviewed commit to the application repository.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c12" value="&lt;b&gt;2. Trigger the CI workflow&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;GitHub Actions&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;OIDC · build · test&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CI workflow&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;GitHub starts build, test, dependency, and security checks.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c11" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;3. Publish a signed immutable image&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Amazon ECR&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Scan · sign · immutable digest&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;release artifact&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The workflow assumes a short-lived, repository-restricted IAM role, scans the image, signs it, and pushes its digest.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c13" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c15" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ecr;pointerEvents=0;" parent="c13" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;4. Open the production promotion PR&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;GitOps repository&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Environment desired state&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;production PR&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;CI updates only the image digest. Development may auto-merge its branch; production requires review and protected-bra…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c19" value="&lt;b&gt;5. Merge approved desired state&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Argo CD&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Management or per-cluster&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;reconciliation&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;After approval and merge, Argo CD detects the new Git revision and compares it with the target cluster.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c18" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c20" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c21" value="&lt;b&gt;6. Reconcile the EKS workload&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Primary EKS&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Production workloads&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;multi-AZ&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Argo applies the approved manifests and verifies Kubernetes health policy.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c20" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c22" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c20" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c23" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c24" value="&lt;b&gt;7. Verify release health&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Health + traffic&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudWatch · Route 53&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;SLO + routing&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;CloudWatch, synthetic checks, and Argo health confirm the release or trigger rollback.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c23" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c25" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;pointerEvents=0;" parent="c23" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c26" value="1. git push" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="2. push event" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="3. OIDC → ECR" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c11" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="4. GitOps pull request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c30" value="5. Git poll / webhook" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c18"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c31" value="6. Argo CD sync" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c18" target="c20"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c32" value="7. metrics + traces" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c20" target="c23"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c33" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c34" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="05f53e4a7d25" name="2. Detect and triage a threat"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Security, DevOps and Disaster Recovery&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Detect and triage a threat&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 2/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Detect, enrich, and triage a security finding.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;A raw alert lacks the identity, configuration, and audit context needed for response.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;GuardDuty and Security Hub produce findings; CloudTrail and Config enter Security Lake; investigators query working data and preserve only selected case material in Object Lock.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Primary EKS&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Production workloads&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;multi-AZ&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Normalize first; preserve case evidence selectively.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c7" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c10" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c11" value="&lt;b&gt;1. Emit a security finding&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Detection&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;GuardDuty · Security Hub&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;findings&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Workload, identity, and network signals produce a normalized finding.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c10" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c12" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.guardduty;pointerEvents=0;" parent="c10" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;2. Correlate security telemetry&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Security telemetry&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudTrail · Config · Security Lake&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;OCSF + audit&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Findings join organization CloudTrail, Config, and supported security sources in Security Lake.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c13" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c15" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.security_lake;pointerEvents=0;" parent="c13" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;3. Open a triage case&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Investigation&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Detective · Athena · case system&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;working copies&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Investigators query normalized telemetry and related entities without changing source records.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.detective;pointerEvents=0;" parent="c16" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;4. Preserve selected evidence&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Evidence vault&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;S3 Object Lock&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;case-specific originals&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Only records material to the case are copied or referenced with source, version, timestamp, and digest.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c19" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c22" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c23" value="&lt;b&gt;5. Create a verified working set&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Investigation&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Detective · Athena · case system&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;working copies&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The investigator receives hash-verified copies while originals remain retention locked.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c22" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c24" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.detective;pointerEvents=0;" parent="c22" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c25" value="1. runtime + identity + network" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="2. OCSF + audit history" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c10" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="3. Athena + Detective" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="4. case manifest" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="5. case export" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c19" target="c22"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c30" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c31" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="bfc18e404e15" name="3. Recover the critical service tier"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Security, DevOps and Disaster Recovery&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Recover the critical service tier&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 3/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Restore the critical service tier after a primary-region impairment.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Regional recovery must include every required dependency and avoid relying on an unavailable primary control plane.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Health checks trigger the runbook; replicated state and artifacts activate in the recovery Region; independent Argo reconciles EKS; synthetic checks pass before Route 53 shifts traffic.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Primary EKS&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Production workloads&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;multi-AZ&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Strategy follows approved RTO and RPO.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c7" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c10" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c11" value="&lt;b&gt;1. Declare regional impairment&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Health + traffic&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudWatch · Route 53&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;SLO + routing&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;SLO breaches and independent health checks satisfy the approved disaster declaration criteria.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c10" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c12" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;pointerEvents=0;" parent="c10" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;2. Activate recovery prerequisites&lt;/b&gt;&lt;br&gt;&lt;