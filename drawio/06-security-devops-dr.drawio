plies the same approved Git revision and scales the recovery workload.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c16" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;4. Run recovery validation&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Health + traffic&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudWatch · Route 53&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;SLO + routing&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Synthetic account, catalog, playback, and dependency checks confirm the stack can serve traffic.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;pointerEvents=0;" parent="c19" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c22" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c23" value="&lt;b&gt;5. Shift production traffic&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Recovery EKS&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;IaC · pilot light / warm&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;tiered by RTO&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Traffic moves only after recovery validation succeeds and split-brain controls are active.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c22" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c24" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c22" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c25" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c26" value="&lt;b&gt;6. Record recovery and failback state&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Security telemetry&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudTrail · Config · Security Lake&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;OCSF + audit&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Promotions, routing changes, approvals, and eventual failback enter the audit trail.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c25" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c27" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.security_lake;pointerEvents=0;" parent="c25" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c28" value="1. health + incident gate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="2. promote / restore" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c10" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c30" value="3. independent Argo sync" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c31" value="4. synthetic API + playback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c32" value="5. Route 53 policy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c19" target="c22"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c33" value="6. organization audit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c22" target="c25"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c34" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c35" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="179addbbc398" name="4. Investigate and contain an incident"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Security, DevOps and Disaster Recovery&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Investigate and contain an incident&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 4/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Collect selected evidence, reconstruct the event, and apply authorized containment.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Response actions must be reproducible and linked to unmodified source evidence.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Security Lake supplies normalized telemetry, the evidence vault protects case originals, investigators work from verified copies, and containment returns to the audit trail.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Detection&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;GuardDuty · Security Hub&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;findings&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Evidence-backed response path.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.guardduty;pointerEvents=0;" parent="c7" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c10" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c11" value="&lt;b&gt;1. Collect the normalized finding set&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Security telemetry&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudTrail · Config · Security Lake&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;OCSF + audit&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Findings, audit events, network records, and workload signals are correlated by principal, resource, request, IP, and…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c10" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c12" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.security_lake;pointerEvents=0;" parent="c10" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;2. Preserve the material case set&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Evidence vault&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;S3 Object Lock&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;case-specific originals&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The collector records origin, object version, timestamp, identity, and digest for each selected item.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c13" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c15" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c13" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;3. Reconstruct from working copies&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Investigation&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Detective · Athena · case system&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;working copies&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The investigator uses verified copies and records queries, exports, conclusions, and uncertainty.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.detective;pointerEvents=0;" parent="c16" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;4. Apply authorized containment&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Primary EKS&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Production workloads&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;multi-AZ&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Approved response revokes credentials, isolates workloads, or changes policy while preserving service safety.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c19" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c22" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c23" value="&lt;b&gt;5. Preserve response history&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Security telemetry&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudTrail · Config · Security Lake&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;OCSF + audit&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Containment actions, approvals, outcomes, and rollback state become part of the audit and case history.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c22" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c24" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.security_lake;pointerEvents=0;" parent="c22" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c25" value="1. security telemetry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="2. evidence manifest" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c10" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="3. Athena + Detective" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="4. revoke / isolate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="5. CloudTrail + case record" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c19" target="c22"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c30" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c31" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
