<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0" compressed="false"><diagram id="73c01157ab7f" name="1. Browse the catalog"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Executive Overview&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Browse the catalog&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 1/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Browse an entitled and region-valid catalog.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Viewers need fast discovery without exposing internal services or unavailable titles.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;WAF and API Gateway validate the request; the application queries authoritative and derived data before returning policy-filtered results.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;customer sessions&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Protected transactional request path.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Enter the public edge&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Public edge&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Route 53 · CloudFront · WAF&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;TLS + DDoS&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;CloudFront serves the application and WAF rejects abusive traffic.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;pointerEvents=0;" parent="c9" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c12" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c13" value="&lt;b&gt;2. Validate the API boundary&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Protected API&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;API Gateway · JWT&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;routing + throttle&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;API Gateway validates the JWT, route, and throttle policy.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c12" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c14" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c15" value="&lt;b&gt;3. Call the OTT application&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Modular services on EKS&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;business APIs&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The request crosses the private integration to the application boundary.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c14" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c16" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c14" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c17" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c18" value="&lt;b&gt;4. Query catalog and rights&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Operational data&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Aurora · OpenSearch&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;authoritative + derived&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The application supplies availability and entitlement constraints to the data query.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c17" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c19" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;pointerEvents=0;" parent="c17" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c20" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c21" value="&lt;b&gt;5. Return safe result candidates&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Modular services on EKS&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;business APIs&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Only candidates valid for the requested market and rights window are returned.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c20" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c22" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c20" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c23" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c24" value="&lt;b&gt;6. Render the catalog&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;customer sessions&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;A final application-side entitlement check protects against stale search data.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c23" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c25" value="1. HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="2. GET /catalog" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="3. private integration" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c12" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="4. SQL + search" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c14" target="c17"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="5. rows + hits" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c17" target="c20"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c30" value="6. 200 OK" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c20" target="c23"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c31" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c32" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="0c40a83a9cef" name="2. Authorize and play content"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Executive Overview&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Authorize and play content&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 2/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Authorize one playback session and deliver protected video.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Business authorization and high-bandwidth media delivery must scale independently.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;The application returns short-lived access to an approved presentation; CloudFront then serves media directly from the protected S3 origin.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;customer sessions&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Control and media data planes stay separate.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Request playback authorization&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Protected API&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;API Gateway · JWT&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;routing + throttle&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The player requests one title for a known device and session.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c12" value="&lt;b&gt;2. Evaluate playback policy&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Modular services on EKS&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;business APIs&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The application evaluates subscription, geography, concurrency, and device policy.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c11" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c13" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c11" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c14" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c15" value="&lt;b&gt;3. Load rights and presentation&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Operational data&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Aurora · OpenSearch&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;authoritative + derived&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Aurora provides rights and asset metadata; OpenSearch is not authoritative for playback.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c14" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c16" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;pointerEvents=0;" parent="c14" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c17" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c18" value="&lt;b&gt;4. Return approved asset&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Modular services on EKS&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;business APIs&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The result identifies the protected presentation and active rights window.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c17" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c19" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eks;pointerEvents=0;" parent="c17" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c20" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c21" value="&lt;b&gt;5. Issue signed playback access&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;customer sessions&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The control plane returns a short-lived manifest URL or signed cookie.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c20" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c22" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c23" value="&lt;b&gt;6. Request the manifest&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Global delivery&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Amazon CloudFront&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;adaptive media&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The player begins the high-bandwidth media path through CloudFront.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c22" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c24" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;pointerEvents=0;" parent="c22" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c25" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c26" value="&lt;b&gt;7. Fetch on cache miss&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Approved media origin&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Amazon S3&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;manifests + segments&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;CloudFront reaches the private S3 origin only when the object is not cached.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c25" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c27" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c25" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c28" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c29" value="&lt;b&gt;8. Return approved media&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Global delivery&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Amazon CloudFront&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;adaptive media&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;S3 returns only objects in the approved origin namespace.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c28" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c30" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;pointerEvents=0;" parent="c28" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c31" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c32" value="&lt;b&gt;9. Start adaptive playback&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;customer sessions&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The player receives cached manifests and segments without proxying video through EKS.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c31" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c33" value="1. POST /playback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c34" value="2. private integration" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c35" value="3. authoritative read" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c11" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c36" value="4. row" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c14" target="c17"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c37" value="5. 200 OK" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c17" target="c20"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c38" value="6. HLS / DASH" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c20" target="c22"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c39" value="7. origin access control" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c22" target="c25"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c40" value="8. manifest + segments" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c25" target="c28"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c41" value="9. edge response" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c28" target="c31"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c42" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c43" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="5453a9de6f86" name="3. Publish content"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Executive Overview&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Publish content&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 3/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Turn a live feed or uploaded file into distributable media.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Devices require validated, encoded, packaged, protected, and approved outputs.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Managed AWS media services process the source; only content that passes its publish gates enters the S3 origin and CloudFront.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Content sources&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Live feeds + uploads&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;contribution&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;High-level managed media path.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Ingest source content&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Managed media processing&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaConvert · MediaLive · MediaPackage v2&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;live + VOD&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The appropriate managed workflow receives the live feed or immutable upload version.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediaconvert;pointerEvents=0;" parent="c9" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c12" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c13" value="&lt;b&gt;2. Publish approved outputs&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Approved media origin&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Amazon S3&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;manifests + segments&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Only technically valid and playback-tested manifests and segments enter the origin.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c12" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c14" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.