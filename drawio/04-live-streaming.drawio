<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0" compressed="false"><diagram id="06ee79339b8d" name="1. Deliver a live event"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Live Streaming Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Deliver a live event&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 1/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Deliver a live source as an adaptive protected stream.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Live events require continuous encoding, device compatibility, rights protection, and low-latency delivery.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;An optional contribution layer feeds a dual-pipeline MediaLive channel; MediaPackage v2 packages and protects, and CloudFront serves viewers.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Live sources&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Cameras · studios&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;primary feed&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Primary managed live path.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Acquire contribution&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Optional contribution&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaConnect&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;route / convert protocols&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;MediaConnect is used only when managed routing, protocol conversion, or distribution is required.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediaconnect;pointerEvents=0;" parent="c9" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c12" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c13" value="&lt;b&gt;2. Feed the standard channel&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;MediaLive&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Dual-input ABR encoding&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;standard channel&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;MediaLive receives the primary and independent backup inputs.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c12" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c14" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_medialive;pointerEvents=0;" parent="c12" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c15" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c16" value="&lt;b&gt;3. Encode the ABR ladder&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;MediaPackage v2&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;JIT packaging · SPEKE DRM&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;LL-HLS / DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;MediaLive produces synchronized adaptive renditions and preserves required ad markers.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c15" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c17" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediapackage;pointerEvents=0;" parent="c15" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c18" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c19" value="&lt;b&gt;4. Package and protect&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;CloudFront&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Protected global delivery&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;low latency&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;MediaPackage v2 applies JIT packaging and SPEKE DRM policy.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c18" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c20" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;pointerEvents=0;" parent="c18" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c21" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c22" value="&lt;b&gt;5. Deliver live media&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer player&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;live session&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;CloudFront serves manifests and segments to the player.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c21" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c23" value="1. SRT / Zixi / RTP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c24" value="2. managed flow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c25" value="3. CMAF ingest" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c12" target="c15"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="4. LL-HLS / DASH" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c15" target="c18"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="5. edge cache" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c18" target="c21"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c29" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="b76dbd2a2479" name="2. Fail over the contribution feed"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Live Streaming Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Fail over the contribution feed&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 2/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Move encoding from an impaired primary input to an independent backup.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;A contribution failure must not terminate a commercially important live event.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Monitoring detects impairment, the managed input policy selects the backup, MediaLive continues output, and operations verifies recovery.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Operations&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudWatch · alarms&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;runbooks&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Input continuity, not regional DR.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;pointerEvents=0;" parent="c7" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c10" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c11" value="&lt;b&gt;1. Detect input impairment&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Optional contribution&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaConnect&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;route / convert protocols&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Loss, corruption, or unacceptable input quality crosses the failover threshold.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c10" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c12" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediaconnect;pointerEvents=0;" parent="c10" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;2. Select the independent backup&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Optional contribution&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaConnect&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;route / convert protocols&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The backup uses an independent source and contribution path so one fault does not remove both feeds.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c13" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c15" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediaconnect;pointerEvents=0;" parent="c13" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;3. Continue channel input&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;MediaLive&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Dual-input ABR encoding&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;standard channel&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;MediaLive receives the backup input under the configured automatic failover policy.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_medialive;pointerEvents=0;" parent="c16" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;4. Verify output recovery&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Operations&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudWatch · alarms&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;runbooks&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Operations confirms encoded output and end-viewer playback before closing the incident.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;pointerEvents=0;" parent="c19" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c22" value="1. CloudWatch alarm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c23" value="2. input failover" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c10" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c24" value="3. controlled switch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c25" value="4. metrics + playback probe" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c27" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="39c6ecd0df54" name="3. Create live-to-VOD content"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Live Streaming Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Create live-to-VOD content&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 3/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Create replay, catch-up, or highlight content from a live event.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Live content should remain monetizable and accessible after the original broadcast window.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;A MediaPackage v2 harvest job writes the selected segment-aligned window to S3; CloudFront then serves the approved replay.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;MediaPackage v2&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;JIT packaging · SPEKE DRM&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;LL-HLS / DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;MediaPackage v2 harvest path.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediapackage;pointerEvents=0;" parent="c7" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c10" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c11" value="&lt;b&gt;1. Create a harvest job&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Harvested live-to-VOD&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaPackage v2 → S3&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;replay clips&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The requested start and end time must fit the endpoint startover window and supported duration.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c10" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c12" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c10" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;2. Publish the approved replay&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;CloudFront&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Protected global delivery&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;low latency&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The harvested manifests and segments enter the protected replay namespace after required checks.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c13" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c15" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;pointerEvents=0;" parent="c13" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;3. Deliver replay content&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer player&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;live session&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The player uses the protected CDN path for catch-up or highlights.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c18" value="1. MediaPackage v2 CreateHarvestJob" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c19" value="2. S3 origin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c10" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c20" value="3. HLS / DASH" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c21" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c22" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="b230bcac4931" name="4. Preserve live forensic telemetry"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Live Streaming Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Preserve live forensic telemetry&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 4/4" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Preserve fingerprints, stream identifiers, and viewer-session records for one live event.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Piracy investigations must connect a recovered stream to its source and distributed session.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Selected contribution, packaging, licence, CDN, and player records enter the Object Lock evidence vault under a case manifest.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Live sources&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Cameras · studios&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;primary feed&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Case evidence remains separate from analytics.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Record source fingerprint&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Live evidence vault&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;S3 Object Lock&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;case-specific&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The platform records contribution fingerprints and trusted timestamps.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,