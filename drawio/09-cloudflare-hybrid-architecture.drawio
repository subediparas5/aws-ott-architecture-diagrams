<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0" compressed="false"><diagram id="a95dd3966f47" name="1. Use the application and APIs"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Cost-Effective Nepal Hybrid OTT Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Use the application and APIs&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 1/6" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Serve the OTT application and an authenticated catalog or account request.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;The inexpensive edge can absorb attacks and cache static assets without moving business truth or authorization into the CDN.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Cloudflare terminates the public request, API Gateway enforces the API contract, Lambda runs business policy at idle and launch, and scale-to-zero state remains authoritative. Containers are added only after a measured runtime or load trigger.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Cloudflare protects the public boundary; AWS remains authoritative.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Enter the Cloudflare edge&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Cloudflare public edge&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;DNS · WAF · DDoS · static app&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Free/Pro scope&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Cloudflare serves the static application and applies DNS, TLS, WAF, rate, and DDoS policy.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c12" value="&lt;b&gt;2. Forward the protected API request&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Protected AWS API&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;API Gateway · private integration&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;control plane&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Only validated dynamic requests continue to the AWS API boundary.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c11" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;3. Call the private application&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Lambda → containers by trigger&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;catalog · rights · playback&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;API Gateway validates the route and JWT before forwarding verified claims through the private integration.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c13" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c15" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;pointerEvents=0;" parent="c13" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;4. Read current business state&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Authoritative state&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Aurora Serverless v2&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;scale to zero · rights · outbox&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The application asks Aurora for current account, catalog, subscription, and rights data.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;pointerEvents=0;" parent="c16" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;5. Return constrained results&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Lambda → containers by trigger&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;catalog · rights · playback&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Aurora returns only the state required for this request.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;pointerEvents=0;" parent="c19" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c22" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c23" value="&lt;b&gt;6. Return the application response&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The viewer receives policy-filtered data; video bytes do not pass through the application compute tier.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c22" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c24" value="1. HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c25" value="2. HTTPS origin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="3. private integration" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c11" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="4. parameterized SQL" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="5. rows" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="6. 200 OK" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c19" target="c22"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c30" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c31" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="f502bf306d8d" name="2. Play VOD from the low-cost origin"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Cost-Effective Nepal Hybrid OTT Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Play VOD from the low-cost origin&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 2/6" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Authorize and deliver immutable VOD or catch-up content from the selected private object origin.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Low-cost object storage and edge caching reduce origin cost, but public buckets or cacheable bearer tokens would expose protected media.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;A Worker validates the public request, the serverless AWS application and authoritative state authorize the session, and the viewer uses a short-lived token against the selected media edge and private origin.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Control and media paths stay separate.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Request playback authorization&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Cloudflare public edge&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;DNS · WAF · DDoS · static app&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Free/Pro scope&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The viewer asks for one asset using an authenticated application session.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c12" value="&lt;b&gt;2. Validate the edge request&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Token validation&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Cloudflare Workers&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;entitlement token&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The Worker checks token shape, route, replay controls, and origin authentication before forwarding.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c11" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c13" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c14" value="&lt;b&gt;3. Forward verified playback context&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Lambda → containers by trigger&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;catalog · rights · playback&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Only normalized account, asset, device, region, and request identifiers reach the application.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c13" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c15" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;pointerEvents=0;" parent="c13" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;4. Evaluate entitlement and rights&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Authoritative state&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Aurora Serverless v2&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;scale to zero · rights · outbox&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Aurora supplies subscription, territory, concurrency, rights window, and presentation metadata.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;pointerEvents=0;" parent="c16" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;5. Return the approved presentation&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;OTT application&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Lambda → containers by trigger&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;catalog · rights · playback&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The result identifies the immutable global-origin presentation only when every policy check passes.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;pointerEvents=0;" parent="c19" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c22" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c23" value="&lt;b&gt;6. Issue short-lived media access&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The application returns a narrowly scoped token and media URL without exposing origin credentials.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c22" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c24" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c25" value="&lt;b&gt;7. Request signed adaptive media&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Replaceable media delivery&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudFront flat · Bunny · enterprise CDN&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;signed HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The media request uses the selected priced delivery service rather than assuming an application CDN includes unlimite…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c24" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c26" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c27" value="&lt;b&gt;8. Fetch immutable objects on miss&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Low-cost global origin&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;R2 · S3 · Bunny Storage&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;immutable VOD · catch-up&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The edge fetches a versioned manifest or segment only after token and cache-key policy succeeds.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c26" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c28" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c29" value="&lt;b&gt;9. Deliver cached media&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The viewer receives adaptive media from the edge; the object origin is not directly public to the player.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c28" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c30" value="1. POST /playback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c31" value="2. Worker route" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c32" value="3. HTTPS origin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c11" target="c13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c33" value="4. authoritative read" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c13" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c34" value="5. row" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c35" value="6. 200 OK" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c19" target="c22"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c36" value="7. HLS / DASH" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c22" target="c24"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c37" value="8. private origin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c24" target="c26"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c38" value="9. edge response" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c26" target="c28"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c39" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c40" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="cf2cf0c098cf" name="3. Publish VOD to the low-cost path"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Cost-Effective Nepal Hybrid OTT Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Publish VOD to the low-cost path&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 3/6" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Create technically valid, protected, immutable VOD packages and publish them to the selected global origin.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Cheap storage does not replace malware checks, source integrity, technical QC, playback QC, rights controls, or rollback.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;The processing pipeline creates ABR outputs, contracted rights services provide keys or marks when needed, and only passing versioned packages are copied to the private origin and tested through the real edge.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Content operations&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CMS · mezzanine upload&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;VOD source&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Publication stays gated even when storage is cheap.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Ingest and process the source&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;VOD processing&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaConvert / FFmpeg · QC&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;ABR · package · protect&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The workflow validates the object version, malware result, source fingerprint, and job id before transcoding.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediaconvert;pointerEvents=0;" parent="c9" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c12" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c13" value="&lt;b&gt;2. Request protection material&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Rights and ad partners&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;DRM · watermark · external ADS&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;contracted services&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Premium packages request keys and forensic policy; non-premium packages explicitly record that protection is not requ…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c12" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c14" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c15" value="&lt;b&gt;3. Return keys and policy&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;VOD processing&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaConvert / FFmpeg · QC&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;ABR · package · protect&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The processing job receives scoped protection material without persisting reusable plaintext keys.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c14" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c16" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_mediaconvert;pointerEvents=0;" parent="c14" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c17" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c18" value="&lt;b&gt;4. Publish the QC-passed version&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Low-cost global origin&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;R2 · S3 · Bunny Storage&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;immutable VOD · catch-up&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Technical QC and playback QC must both pass before the immutable package prefix becomes active.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c17" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;5. Run a real edge playback check&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Low-cost global origin&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;R2 · S3 · Bunny Storage&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;immutable VOD · catch-up&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;A synthetic client fetches the manifest, keys, captions, and sample segments through the production token and cache r…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c22" value="&lt;b&gt;6. Expose the approved presentation&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The application activates version 4 only after the edge playback check succeeds; rollback keeps version 3 intact.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c21" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c23" value="1. upload event" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c24" value="2. DRM / watermark contract" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c25" value="3. SPEKE / vendor API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c12" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="4. private object write" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c14" target="c17"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="5. signed synthetic request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c17" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="6. catalog activation" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c19" target="c21"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c30" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="172c76702dff" name="4. Deliver premium live through the selected CDN"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Cost-Effective Nepal Hybrid OTT Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Deliver premium live through the selected CDN&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 4/6" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Publish a redundant premium live event with DRM, watermarking, SSAI, and contracted edge delivery.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;The largest savings come from delivery, while the hardest correctness requirements remain in contribution, encoding, packaging, rights, ads, and failover.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Dual live inputs feed the AWS managed live pipeline; partner services return rights and ad decisions; the selected media edge distributes the resulting manifests and cacheable segments.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Live contribution&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Dual SRT / RIST feeds&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;A/B inputs&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;AWS creates the protected stream; the contracted CDN distributes it.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Ingest independent live feeds&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Premium live pipeline&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaLive · MediaPackage · MediaTailor&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;dual input · DRM · SSAI&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Two contribution and input paths enter redundant encoders so a single feed or encoder failure does not end the event.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_medialive;pointerEvents=0;" parent="c9" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c12" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c13" value="&lt;b&gt;2. Request DRM, watermark, and ads&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Rights and ad partners&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;DRM · watermark · external ADS&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;contracted services&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;MediaPackage and MediaTailor request protection and ad decisions with privacy-safe session and opportunity context.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c12" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c14" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c15" value="&lt;b&gt;3. Return protected playback policy&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Premium live pipeline&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;MediaLive · MediaPackage · MediaTailor&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;dual input · DRM · SSAI&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Partner responses supply scoped keys, watermark policy, eligible creative, and tracking metadata.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c14" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c16" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elemental_medialive;pointerEvents=0;" parent="c14" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c17" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c18" value="&lt;b&gt;4. Publish the premium origin&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Replaceable media delivery&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudFront flat · Bunny · enterprise CDN&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;signed HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The AWS live path exposes an authenticated, redundant origin manifest and cacheable content/ad segments to the contra…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c17" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c19" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c20" value="&lt;b&gt;5. Request signed live playback&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Replaceable media delivery&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudFront flat · Bunny · enterprise CDN&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;signed HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The viewer presents short-lived access; the edge applies geography, token, cache, and attack controls.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c19" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c21" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c22" value="&lt;b&gt;6. Deliver live content and ads&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The player receives personalized manifests and adaptive content/ad segments without sending bulk video through the ap…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c21" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c23" value="1. dual SRT / RIST" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c24" value="2. SPEKE + VAST" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c25" value="3. keys + ad metadata" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c12" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="4. HLS / DASH origin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c14" target="c17"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="5. manifest request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c17" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="6. edge response" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c19" target="c21"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c29" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c30" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="bc011e480b47" name="5. Activate the Nepal origin and cache tier"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Cost-Effective Nepal Hybrid OTT Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Activate the Nepal origin and cache tier&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 5/6" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Replicate approved media into a Nepal managed origin/cache tier and serve eligible Nepal sessions locally with global failback.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Keeping popular bytes inside Nepal can reduce international transfer and startup time, but only if facility, carrier, operations, and recovery costs are lower than the CDN alternative.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Approved immutable versions replicate from the global origin; the selected CDN or traffic policy uses the Nepal route only while health, token, rights, and QoE gates pass.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Low-cost global origin&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;R2 · S3 · Bunny Storage&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;immutable VOD · catch-up&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Local infrastructure is a measured scale optimization, not the launch baseline.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Replicate approved immutable packages&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Nepal origin / cache tier&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Managed IaaS or colocation&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;DataHub · Ncell · DataWorld RFP&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Only active, QC-passed package versions replicate to the Nepal tier; deletion and overwrite are not used as publicati…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c12" value="&lt;b&gt;2. Record the Nepal inventory digest&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;AWS recovery + evidence&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;S3 versioning · Object Lock&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;separate buckets/accounts&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The site exports object inventory, configuration, provider, and deployment state so drift and recovery remain measura…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c11" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c13" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c11" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c14" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c15" value="&lt;b&gt;3. Request signed Nepal playback&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Replaceable media delivery&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudFront flat · Bunny · enterprise CDN&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;signed HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The viewer uses the same short-lived token and cache key regardless of which healthy delivery route is selected.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c14" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c16" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c17" value="&lt;b&gt;4. Use the healthy Nepal route&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Nepal origin / cache tier&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Managed IaaS or colocation&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;DataHub · Ncell · DataWorld RFP&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The media edge fetches locally only when entitlement scope, provider health, object version, and geography are eligib…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c16" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c18" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c19" value="&lt;b&gt;5. Return the verified local object&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Replaceable media delivery&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;CloudFront flat · Bunny · enterprise CDN&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;signed HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The Nepal tier returns the same immutable representation; a miss or health failure falls back to the global origin.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c18" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c20" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="560" width="220" height="180" as="geometry"/></mxCell><mxCell id="c21" value="&lt;b&gt;6. Deliver locally cached media&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Viewer applications&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Web · mobile · TV&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;HTTPS · HLS · DASH&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;The viewer receives the selected representation while QoE, cache hit, route, bytes, and cost remain observable.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c20" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c22" value="1. versioned object sync" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c7" target="c9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c23" value="2. inventory + audit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c9" target="c11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c24" value="3. HLS / DASH" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c11" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c25" value="4. private origin / cache" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c14" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c26" value="5. manifest / segment" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c16" target="c18"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c27" value="6. edge response" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;fontColor=#333333;fontSize=9;" edge="1" parent="1" source="c18" target="c20"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c28" value="Legend · External / actor · Edge / orchestration · Compute / media · Processing · Data / evidence · Operations / security" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;fontColor=#555555;fontSize=11;" parent="1" vertex="1"><mxGeometry x="170" y="790" width="1260" height="38" as="geometry"/></mxCell><mxCell id="c29" value="Use the page tabs to switch flows. Repeated services are intentional: each card is one numbered handoff occurrence." style="text;html=1;align=center;verticalAlign=middle;fontColor=#777777;fontSize=11;" parent="1" vertex="1"><mxGeometry x="250" y="840" width="1100" height="25" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="17c19e6ed192" name="6. Preserve evidence and recovery copies"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="&lt;b&gt;Cost-Effective Nepal Hybrid OTT Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:18px&#x27;&gt;Preserve evidence and recovery copies&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontColor=#232f3e;" parent="1" vertex="1"><mxGeometry x="40" y="20" width="1180" height="55" as="geometry"/></mxCell><mxCell id="c3" value="Editable Draw.io · Flow 6/6" style="text;html=1;align=right;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1"><mxGeometry x="1240" y="28" width="320" height="35" as="geometry"/></mxCell><mxCell id="c4" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Correlate delivery activity, preserve selected case evidence, and restore media after a destructive, provider, or regional event.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="40" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c5" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;A lower-cost route is acceptable only when the service can investigate abuse and recover without trusting one provider or one mutable log store.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="550" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c6" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;Cloudflare, CDN, Nepal provider, AWS, and application records enter the security workflow; selected case material and independent recovery copies are retained in AWS; restore is integrity- and playback-gated.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=12;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#232f3e;fontSize=14;" parent="1" vertex="1"><mxGeometry x="1060" y="85" width="490" height="145" as="geometry"/></mxCell><mxCell id="c7" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="40" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c8" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Cloudflare public edge&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;DNS · WAF · DDoS · static app&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Free/Pro scope&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;No CDN, cloud, or Nepal facility becomes the only copy or audit source.&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c7" vertex="1"><mxGeometry x="12" y="12" width="196" height="156" as="geometry"/></mxCell><mxCell id="c9" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="340" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c10" value="&lt;b&gt;1. Export edge security records&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;AWS recovery + evidence&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;S3 versioning · Object Lock&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;separate buckets/accounts&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;WAF, request, token, configuration, and administrator events are exported with UTC time and stable request identifier…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c9" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c11" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c9" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c12" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="640" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c13" value="&lt;b&gt;2. Export media delivery records&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;AWS recovery + evidence&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;S3 versioning · Object Lock&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;separate buckets/accounts&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Cache result, origin status, token outcome, bytes, asset, session, and edge location support QoE, fraud, and incident…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c12" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c14" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c12" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c15" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="940" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c16" value="&lt;b&gt;3. Preserve application and recovery state&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;AWS recovery + evidence&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;S3 versioning · Object Lock&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;separate buckets/accounts&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Application decisions, GitOps revisions, global and Nepal inventories, configuration, and independent media copies en…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c15" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c17" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;pointerEvents=0;" parent="c15" vertex="1"><mxGeometry x="10" y="14" width="42" height="42" as="geometry"/></mxCell><mxCell id="c18" value="" style="rounded=1;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="1240" y="270" width="220" height="180" as="geometry"/></mxCell><mxCell id="c19" value="&lt;b&gt;4. Open a verified case or recovery run&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px&#x27;&gt;&lt;b&gt;Security operations&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;Security Lake · case workflow&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:10px;color:#555555&#x27;&gt;correlation · investigation&lt;/span&gt;&lt;br&gt;&lt;span style=&#x27;font-size:9px;color:#777777&#x27;&gt;Security operations correlate working data and promote only material originals, versions, timestamps, identities, and…&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=0;fontColor=#232f3e;fontSize=11;" parent="c18" vertex="1"><mxGeometry x="62" y="12" width="146" height="156" as="geometry"/></mxCell><mxCell id="c20" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed